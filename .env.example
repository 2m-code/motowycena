# SMTP - contact form.
SMTP_HOST=sXX.cyber-folks.pl
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=biuro@eprzyczepy.eu
SMTP_PASS=HASLO_DO_SKRZYNKI_EMAIL
MAIL_FROM=biuro@eprzyczepy.eu
MAIL_TO=biuro@eprzyczepy.eu

# Allowed website origins for /api/contact.
CORS_ORIGIN=https://www.eprzyczepy.eu,https://eprzyczepy.eu

# Mail server port for local/dev. Cyber_Folks usually injects PORT in the Node app panel.
MAIL_SERVER_PORT=3001

# Admin panel at /admin. Set long random values in production.
ADMIN_PASSWORD=change-me
ADMIN_SESSION_SECRET=change-this-to-a-long-random-secret

# Cloudflare Turnstile (anti-bot). Free at https://dash.cloudflare.com/?to=/:account/turnstile
# Site key is public (used in browser); secret key is server-only.
# Server exposes the site key at runtime via /api/config (see server.ts).
# Leave both empty in dev to skip captcha verification.
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
